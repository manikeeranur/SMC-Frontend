# Backend URL (local)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Backend URL (production — uncomment for prod)
# NEXT_PUBLIC_API_URL=https://smc-backend-yheu.onrender.com
# NEXT_PUBLIC_WS_URL=wss://smc-backend-yheu.onrender.com

